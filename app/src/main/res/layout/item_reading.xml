<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Timestamp row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_history"
                android:layout_marginEnd="6dp"
                android:contentDescription="Time"/>
            <TextView
                android:id="@+id/tvTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2024-03-10 12:00:00"
                android:textSize="12sp"
                android:textColor="@color/purple_200"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">
            <TextView android:id="@+id/tvBpm" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="BPM: 82" android:textColor="@color/text_primary" android:textSize="13sp"/>
            <TextView android:id="@+id/tvSpo2" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="SpO2: 97%" android:textColor="@color/text_primary" android:textSize="13sp"/>
            <TextView android:id="@+id/tvAlert" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Alert: NONE" android:textColor="@color/vital_alert" android:textStyle="bold" android:textSize="13sp"/>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">
            <TextView android:id="@+id/tvBreath" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Breath: 540" android:textColor="@color/text_secondary" android:textSize="13sp"/>
            <TextView android:id="@+id/tvSmoke" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Smoke: 120" android:textColor="@color/text_secondary" android:textSize="13sp"/>
            <TextView android:id="@+id/tvMed" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="MED: 300" android:textColor="@color/text_secondary" android:textSize="13sp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
