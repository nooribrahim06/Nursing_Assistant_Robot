<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- ── Header ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_heartbeat"
            android:layout_marginEnd="12dp"
            android:contentDescription="RoboCare"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RoboCare"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select a patient to begin monitoring"
        android:textSize="14sp"
        android:textColor="@color/text_hint"
        android:layout_marginBottom="20dp"
        android:layout_marginStart="36dp"/>

    <!-- ── Empty state ────────────────────────────────── -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No patients yet.\nAdd a patient to begin."
        android:textSize="15sp"
        android:gravity="center"
        android:padding="48dp"
        android:textColor="@color/text_hint"
        android:visibility="gone"
        android:lineSpacingExtra="4dp"/>

    <!-- ── Patient list ───────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPatients"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

    <!-- ── Bottom actions ─────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddPatient"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Add Patient"
            android:layout_marginEnd="6dp"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/white"
            app:cornerRadius="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBluetooth"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Bluetooth"
            android:layout_marginStart="6dp"
            app:icon="@drawable/ic_bluetooth"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            style="@style/RoboCare.Button.Outlined"/>
    </LinearLayout>

</LinearLayout>
