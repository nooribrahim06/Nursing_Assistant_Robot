<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_dark"
    android:padding="24dp">

    <!-- ── Header ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_gamepad"
            android:layout_marginEnd="10dp"
            android:contentDescription="Motion Control"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Motion Control"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- ── Mode indicator ─────────────────────────────── -->
    <TextView
        android:id="@+id/tvMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LINE TRACKING MODE"
        android:textSize="12sp"
        android:letterSpacing="0.1"
        android:textColor="@color/status_disconnected"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEnterPhone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Phone Control"
        android:layout_marginBottom="32dp"
        app:cornerRadius="14dp"/>

    <!-- ── D-pad: Forward ─────────────────────────────── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnForward"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:text="▲"
        android:textSize="28sp"
        android:layout_marginBottom="8dp"
        app:backgroundTint="@color/bg_card"
        android:textColor="@color/purple_200"
        app:cornerRadius="16dp"/>

    <!-- ── D-pad: Left / Stop / Right ─────────────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeft"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="◄"
            android:textSize="28sp"
            android:layout_marginEnd="8dp"
            app:backgroundTint="@color/bg_card"
            android:textColor="@color/purple_200"
            app:cornerRadius="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="STOP"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/status_disconnected"
            app:cornerRadius="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRight"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="►"
            android:textSize="28sp"
            android:layout_marginStart="8dp"
            app:backgroundTint="@color/bg_card"
            android:textColor="@color/purple_200"
            app:cornerRadius="16dp"/>
    </LinearLayout>

    <!-- ── D-pad: Backward ────────────────────────────── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackward"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:text="▼"
        android:textSize="28sp"
        app:backgroundTint="@color/bg_card"
        android:textColor="@color/purple_200"
        app:cornerRadius="16dp"/>

    <!-- ── Debug log ──────────────────────────────────── -->
    <TextView
        android:id="@+id/tvLastCommand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Last command: none"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:textColor="@color/text_hint"
        android:background="@drawable/bg_card_light_rounded"
        android:padding="12dp"
        android:layout_marginTop="24dp"
        android:gravity="center"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Robot returns to Line Tracker on exit"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:layout_marginTop="12dp"/>

</LinearLayout>
