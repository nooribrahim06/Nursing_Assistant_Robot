<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            app:icon="@drawable/ic_arrow_back"
            app:iconTint="@color/white"
            style="@style/RoboCare.Button.Outlined"/>
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_medication"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="Medicines"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medicines"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvPatientInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Patient: --"
        android:textColor="@color/text_hint"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"/>

    <!-- Add Form -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ADD MEDICINE"
            style="@style/RoboCare.Text.SectionTitle"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Medicine Name (e.g. Panadol)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@drawable/bg_card_light_rounded"
            android:padding="14dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etDose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Dose (e.g. 500 mg)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@drawable/bg_card_light_rounded"
            android:padding="14dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Notes (e.g. After food)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@drawable/bg_card_light_rounded"
            android:padding="14dp"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/cbActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active"
            android:checked="true"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Medicine"
            app:cornerRadius="12dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ASSIGNED MEDICINES"
        style="@style/RoboCare.Text.SectionTitle"
        android:layout_marginBottom="10dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMedicines"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"/>
</LinearLayout>
