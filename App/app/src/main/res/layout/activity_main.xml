<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="28dp">

    <!-- ── Spacer to push content down a bit ──────────── -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── Logo icon ──────────────────────────────────── -->
    <FrameLayout
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_icon_circle"/>

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_heartbeat"
            android:contentDescription="RoboCare logo"/>
    </FrameLayout>

    <!-- ── App title ──────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RoboCare"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.05"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Robot control &amp; patient monitoring"
        android:textSize="14sp"
        android:textColor="@color/text_hint"
        android:layout_marginBottom="16dp"/>

    <!-- ── Connection status pill ─────────────────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_card_rounded"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:layout_marginBottom="32dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_status_dot"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISCONNECTED"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="@color/status_disconnected"/>
    </LinearLayout>

    <!-- ── Navigation cards ───────────────────────────── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPatients"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Patients"
        android:layout_marginBottom="10dp"
        app:icon="@drawable/ic_patients"
        style="@style/RoboCare.Button.Nav"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBluetooth"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Bluetooth"
        android:layout_marginBottom="10dp"
        app:icon="@drawable/ic_bluetooth"
        style="@style/RoboCare.Button.Nav"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnMotion"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Motion Control"
        android:layout_marginBottom="10dp"
        app:icon="@drawable/ic_gamepad"
        style="@style/RoboCare.Button.Nav"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTftRemote"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="TFT Remote"
        app:icon="@drawable/ic_remote"
        style="@style/RoboCare.Button.Nav"/>

    <!-- ── Bottom spacer ──────────────────────────────── -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── Footer ─────────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:layout_marginTop="12dp"/>

</LinearLayout>
