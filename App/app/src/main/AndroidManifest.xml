<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet for Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Bluetooth Permissions -->
    <!-- For Android 12+ (API 31+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- For Android 11 and lower -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" android:maxSdkVersion="30" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.RoboCareMonitor"
        tools:targetApi="31">

        <activity
            android:name=".activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activities.PatientListActivity" android:label="Patients" />
        <activity android:name=".activities.AddPatientActivity" android:label="Add Patient" />
        <activity android:name=".activities.BluetoothConnectActivity" android:label="Bluetooth Setup" />
        <activity android:name=".activities.DashboardActivity" android:label="Live Dashboard" />
        <activity android:name=".activities.HistoryActivity" android:label="History" />
        <activity android:name=".activities.MedicinesActivity" android:label="Medicines" />
        <activity android:name=".activities.MotionControlActivity" android:label="Motion Control" />
        <activity android:name=".activities.TftRemoteActivity" android:label="TFT Remote" />

    </application>

</manifest>
